<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <template class="DinoUiGeneralPreferencesPage" parent="AdwPreferencesPage">
    <child>
      <object class="AdwPreferencesGroup">
        <child>
          <object class="AdwSwitchRow" id="typing_row">
            <property name="title" translatable="yes">Send _Typing Notifications</property>
            <property name="use-underline">True</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="marker_row">
            <property name="title" translatable="yes">Send _Read Receipts</property>
            <property name="use-underline">True</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <child>
          <object class="AdwSwitchRow" id="dark_theme_row">
            <property name="title" translatable="yes">Use _Dark Theme</property>
            <property name="subtitle" translatable="yes">Toggle between dark and light appearance</property>
            <property name="use-underline">True</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="notification_row">
            <property name="title" translatable="yes">_Notifications</property>
            <property name="subtitle" translatable="yes">Notify when a new message arrives</property>
            <property name="use-underline">True</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <child>
          <object class="AdwSwitchRow" id="emoji_row">
            <property name="title" translatable="yes">_Convert Smileys to Emoji</property>
            <property name="use-underline">True</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Vacation Notice</property>
        <child>
          <object class="AdwSwitchRow" id="vacation_notice_row">
            <property name="title" translatable="yes">_Enable Vacation Notice</property>
            <property name="subtitle" translatable="yes">Auto-reply to incoming messages with the
              text below</property>
            <property name="use-underline">True</property>
          </object>
        </child>
        <child>
          <object class="AdwEntryRow" id="vacation_message_row">
            <property name="title" translatable="yes">Vacation message</property>
            <property name="sensitive">False</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>